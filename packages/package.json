{
  "name": "@banksalad/overlay-kit",
  "version": "1.8.6",
  "description": "Next-generation tools for managing overlays",
  "keywords": [
    "overlay",
    "react"
  ],
  "homepage": "https://overlay-kit.slash.page",
  "bugs": "https://github.com/banksalad/overlay-kit/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banksalad/overlay-kit.git",
    "directory": "packages"
  },
  "license": "MIT",
  "author": {
    "name": "Yongbeen Im",
    "email": "been.im@toss.im"
  },
  "sideEffects": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage --typecheck",
    "test:attw": "attw --pack",
    "test:publint": "publint"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.0.0",
    "publint": "^0.3.17",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^16.8 || ^17 || ^18 || ^19",
    "react-dom": "^16.8 || ^17 || ^18 || ^19"
  }
}
